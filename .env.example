# Copy to .env and fill in. NEVER commit .env (it holds real secrets).
# config.yaml references these via ${VAR} placeholders; missing vars fail fast.
# Loaded automatically from $TGFS_DATA_DIR/.env, or inject via the environment.

# Telegram
TG_API_HASH=
TG_BOT_TOKEN_1=
TG_BOT_TOKEN_2=

# WebDAV user password
TGFS_USER_PASSWORD=

# JWT signing secret (any long random string)
TGFS_JWT_SECRET=

# GitHub fine-grained PATs (Contents: read/write on the metadata repos)
GH_PAT_MOVIES=
GH_PAT_TV=
