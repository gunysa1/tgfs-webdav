# Copy to secrets.env and fill in. NEVER commit secrets.env (it holds real secrets).
# config.yaml references these via ${VAR} placeholders; missing vars fail fast.
# In Docker, secrets.env is bind-mounted to $TGFS_DATA_DIR/.env and loaded at startup.
# (Named secrets.env, not .env, so Docker Compose does not auto-interpolate it.)

# Telegram
TG_API_HASH=
TG_BOT_TOKEN_1=
TG_BOT_TOKEN_2=

# WebDAV user password
TGFS_USER_PASSWORD=

# JWT signing secret (any long random string)
TGFS_JWT_SECRET=

# GitHub fine-grained PATs (Contents: read/write on the metadata repos)
GH_PAT_MOVIES=
GH_PAT_TV=
